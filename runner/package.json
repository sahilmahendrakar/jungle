{
  "name": "jungle-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Jungle agent-runner: a long-lived process that bridges a Claude Agent SDK session to the Jungle backend over one outbound WebSocket.",
  "main": "dist/index.js",
  "bin": {
    "jungle-runner": "dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "node scripts/sync-protocol.mjs",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "dev": "tsc -p tsconfig.json && node dist/index.js",
    "mock": "node test/mock-backend.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.198",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/ws": "8.5.13",
    "typescript": "5.7.3"
  }
}
