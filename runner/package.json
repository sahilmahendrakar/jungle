{
  "name": "jungle-runner",
  "version": "0.1.0",
  "type": "module",
  "description": "Run Jungle agents on your own machine: `jungle-runner connect` registers this device and runs the agents you assign to it from the Jungle web app.",
  "keywords": ["jungle", "agents", "self-hosted", "runner", "cli"],
  "license": "MIT",
  "homepage": "https://jungleagents.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/sahilmahendrakar/jungle.git",
    "directory": "runner"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "bin": {
    "jungle-runner": "dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/sync-protocol.mjs",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "dev": "tsc -p tsconfig.json && node dist/index.js",
    "mock": "node test/mock-backend.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.198",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/ws": "8.5.13",
    "typescript": "5.7.3"
  }
}
