# Copy to .env and fill in values.
DATABASE_URL=postgresql://jungle:jungle@127.0.0.1:5432/jungle
ANTHROPIC_API_KEY=

# Optional — open-source models via Anthropic-compatible endpoints (backend/src/providers.ts).
# Set the key to enable that model in the picker; leaving it unset makes selecting the model
# return a clear 400. Z_AI_API_KEY = z.ai, which serves GLM 5.2 (get one at https://z.ai).
# Z_AI_API_KEY=

# Optional — required for GitHub-capable agents (see scripts/setup-github-agent.mjs)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_APP_PRIVATE_KEY=

# --- Google OAuth (Gmail + Google Drive integrations; backend/src/google.ts) ---
# One OAuth client (Google Cloud Console > Credentials). All connections are per-user (Settings →
# Connections). Gmail uses the GOOGLE_OAUTH_REDIRECT_URI callback; Google Drive uses the generic
# /auth/integrations/callback on the backend's public origin (BACKEND_PUBLIC_URL below, or derived
# from GOOGLE_OAUTH_REDIRECT_URI's origin). Add BOTH callbacks to the OAuth client's redirect URIs,
# and enable the Gmail + Drive APIs + their scopes on the consent screen.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://api.jungleagents.com/auth/google/callback

# Backend public origin, used to build the per-user integration OAuth callback
# (<origin>/auth/integrations/callback) for Linear/Notion/Granola/Google Drive. Defaults to the
# origin of GOOGLE_OAUTH_REDIRECT_URI, else http://localhost:3001.
# BACKEND_PUBLIC_URL=https://api.jungleagents.com

# --- Firebase Auth (real Google sign-in) ---
# When these are set, the app uses Google sign-in + onboarding. When unset, it falls back to
# the legacy ?as= dev sign-in (and the Playwright suites keep working). All in one file:
# only VITE_-prefixed vars reach the frontend bundle; the rest stay server-side.

# Backend — Firebase Admin service account (Project settings > Service accounts >
# "Generate new private key"). Paste the whole JSON on one line, or point to a file path.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=/home/ec2-user/.config/jungle/firebase-sa.json

# Backend — where the SPA is served (GitHub OAuth callback redirects back here).
# FRONTEND_URL=http://localhost:5173
# Force the dev (?as=) bypass on even when Firebase is configured (default off in that case).
# AUTH_DEV_BYPASS=1

# Frontend — Firebase web app config (Project settings > your web app). Public, not secret.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# --- Fly Machines runner provider (backend/src/provisioner-fly.ts) ---
# Secret — a Fly deploy token (`fly tokens create deploy -a jungle-runners`); quote it, it
# contains a space. Only required once RUNNER_PROVIDER=fly or a request opts an agent into Fly.
# FLY_API_TOKEN="FlyV1 ..."
# FLY_APP=jungle-runners
# FLY_REGION=iad
# FLY_RUNNER_IMAGE=registry.fly.io/jungle-runners:v1
# Backend's public runner-facing origin (matches the runner protocol's JUNGLE_BACKEND_WS).
# RUNNER_BACKEND_WS=wss://api.jungleagents.com/api/runner
# Default runner_provider for newly-created agents: 'docker' (default) or 'fly'.
# RUNNER_PROVIDER=docker
# Seconds an idle runner with an empty inbox may sit connected before its machine is stopped
# (0 disables idle-stop). Applies to docker and fly agents alike.
# RUNNER_IDLE_STOP_SECONDS=60
