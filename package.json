{
  "name": "jungle",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Jungle — Slack-style app for chatting with cloud agents that do real work",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:up": "node scripts/db-up.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:down": "node scripts/db-down.mjs",
    "setup": "npm install && node scripts/db-up.mjs && node scripts/db-migrate.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:backend": "npm run dev -w @jungle/backend",
    "dev:frontend": "npm run dev -w @jungle/frontend"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "playwright": "^1.61.1"
  }
}
